      "rdfs:label": { "@value": "R13 has referring entity", "@language": "en" },
      "rdfs:subPropertyOf": { "@id": "intro:R24_hasRelatedEntity" },
      "owl:inverseOf": { "@id": "intro:R13i_isReferringEntity" },
      "rdfs:domain": { "@id": "intro:INT3_Interrelation" },

            { "@id": "intro:INT2_ActualizationOfFeature" },
            { "@id": "intro:INT6_Architext" }
          ]
        }
      },
      "rdfs:comment": { "@value": "Links an INT3 Interrelation to a referring entity.", "@language": "en" }
    },

    {
      "@id": "intro:R13i_isReferringEntity",
      "@type": "owl:ObjectProperty",
      "rdfs:label": { "@value": "R13i is referring entity", "@language": "en" },
      "owl:inverseOf": { "@id": "intro:R13_hasReferringEntity" },
      "rdfs:subPropertyOf": { "@id": "intro:R24i_isRelatedEntity" },

    },

    {
      "@id": "ecrm:P14i_performed",
      "@type": "owl:ObjectProperty",
      "rdfs:label": [
        { "@value": "P14 performed", "@language": "en" },
        { "@value": "P14 führte aus", "@language": "de" },
        { "@value": "P14 a effectué", "@language": "fr" },
        { "@value": "P14 执行", "@language": "zh" }

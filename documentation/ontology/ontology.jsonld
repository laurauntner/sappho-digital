      "owl:inverseOf": { "@id": "intro:R24_hasRelatedEntity" },
      "rdfs:domain": {
        "@type": "owl:Class",
        "owl:unionOf": {
          "@list": [
            { "@id": "lrmoo:F1_Work" },
            { "@id": "crm:E73_Information_Object" },
            { "@id": "intro:INT1_Passage" },
            { "@id": "intro:INT2_ActualizationOfFeature" },
            { "@id": "intro:INT6_Architext" }
          ]
        }
      },
      "rdfs:range": { "@id": "intro:INT3_Interrelation" }
    },


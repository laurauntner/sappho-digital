    },

    {
      "@id": "intro:R17i_featureActualizedIn",
      "@type": "owl:ObjectProperty",
      "rdfs:label": { "@value": "R17i feature actualized in", "@language": "en" },
      "owl:inverseOf": { "@id": "intro:R17_actualizesFeature" },
      "rdfs:domain": { "@id": "intro:INT4_Feature" },
      "rdfs:range": { "@id": "intro:INT2_ActualizationOfFeature" }
    },

    {
      "@id": "intro:R18_showsActualization",
      "@type": "owl:ObjectProperty",
      "rdfs:label": { "@value": "R18 shows actualization", "@language": "en" },
      "owl:inverseOf": { "@id": "intro:R18i_actualizationFoundOn" },
      "rdfs:domain": {
        "@type": "owl:Class",
        "owl:unionOf": {
          "@list": [
            { "@id": "lrmoo:F1_Work" },
            { "@id": "crm:E73_Information_Object" },
            { "@id": "intro:INT1_Passage" },
            { "@id": "intro:INT2_ActualizationOfFeature" },
            { "@id": "intro:INT6_Architext" }
          ]
        }
      },
      "rdfs:range": { "@id": "intro:INT2_ActualizationOfFeature" },
      "rdfs:comment": { "@value": "Links a text or an image (on any ontological level) or an INT2 Actualization of Feature to an INT2 Actualization of Feature found on it.", "@language": "en" }
    },

    {
      "@id": "intro:R18i_actualizationFoundOn",
      "@type": "owl:ObjectProperty",
      "rdfs:label": { "@value": "R18i actualization found on", "@language": "en" },

            { "@id": "intro:INT2_ActualizationOfFeature" },
            { "@id": "intro:INT6_Architext" }
          ]
        }
      },
      "rdfs:comment": { "@value": "Links an INT3 Interrelation to the entity referred to in the relationship.", "@language": "en" }
    },

    {
      "@id": "intro:R12i_isReferredToEntity",

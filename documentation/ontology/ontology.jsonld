            { "@id": "intro:INT1_Passage" },
            { "@id": "intro:INT2_ActualizationOfFeature" },
            { "@id": "intro:INT6_Architext" }
          ]
        }
      },
      "rdfs:comment": { "@value": "Links any INT3 Interrelation to a text or image (on any ontological level) or INT2 Actualization of Feature that is part of the INT3 Interrelation.", "@language": "en" },
